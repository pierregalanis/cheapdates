        {
          "icon": "./assets/images/icon.png",
          "color": "#FF6B1A",
          "sounds": [],
          "mode": "production"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2ec7fe66-27ee-47ed-8bb8-0d637f3efa1f"
      }
    }
  }
}
